rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(relationshipId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/relationships/$(relationshipId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /invites/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    function isJoinableRelationship() {
      return isSignedIn()
        && resource.data.memberIds.size() < 2
        && !(request.auth.uid in resource.data.memberIds);
    }

    function isJoinUpdate() {
      return isJoinableRelationship()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberIds', 'memberDisplayNames']);
    }

    match /relationships/{relationshipId} {
      allow read: if isMember(relationshipId) || isJoinableRelationship();
      allow create: if isSignedIn();
      allow update: if isMember(relationshipId) || isJoinUpdate();

      match /presence/{userId} {
        allow read: if isMember(relationshipId);
        allow write: if isMember(relationshipId) && request.auth.uid == userId;
      }

      match /moments/{momentId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.userId == request.auth.uid;
      }

      match /letters/{letterId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.fromUserId == request.auth.uid;
      }

      match /memories/{memoryId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.userId == request.auth.uid;
      }

      match /play/{sessionId} {
        allow read: if isMember(relationshipId);
        allow create, update: if isMember(relationshipId);
      }

      match /reminders/{reminderId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.createdBy == request.auth.uid;
      }

      match /stories/{storyId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.fromUserId == request.auth.uid;
      }

      match /liveCanvas/{canvasId} {
        allow read: if isMember(relationshipId);
        allow create, update: if isMember(relationshipId);
      }

      match /moodHistory/{entryId} {
        allow read: if isMember(relationshipId);
        allow create: if isMember(relationshipId)
          && request.resource.data.userId == request.auth.uid;
      }
    }
  }
}
